# Required
OPENAI_API_KEY=sk-...

# Set to "production" on Railway
ENVIRONMENT=development

# Railway provides this automatically when you add a Redis plugin
REDIS_URL=redis://localhost:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
IP_HASH_SALT=your-random-secret-here

# Your Railway app URL (e.g. https://your-app.up.railway.app)
# Only needed in production for CORS
ALLOWED_ORIGIN=

# Optional: tune rate limiting (defaults: 10 requests per hour)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=3600
